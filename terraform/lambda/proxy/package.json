{
  "scripts": {
    "build": "(npm install || true) && run-script-os",
    "build:macos:linux": "npm install --omit=dev && npx tsc",
    "build:default": "npm install --omit=dev ; npx tsc",
    "postbuild": "npx run-script-os",
    "postbuild:macos:linux": "cp package*.json dist && cd dist && npm i --omit=dev",
    "postbuild:default": "copy package*.json dist ; cd dist ; npm i --omit=dev"
  },
  "devDependencies": {
    "@types/aws-lambda": "^8.10.149",
    "@types/node": "^22.19.17",
    "run-script-os": "^1.1.6",
    "typescript": "^5.8.3"
  },
  "dependencies": {
    "@types/node-fetch": "^2.6.13",
    "node-fetch": "^3.3.2"
  }
}
